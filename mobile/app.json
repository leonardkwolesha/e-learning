{
  "expo": {
    "name": "EduAI OS",
    "slug": "eduai-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eduaios.app"
    },
    "android": {
      "package": "com.eduaios.app",
      "backgroundColor": "#0a0a0f"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "Allow EduAI OS to access your microphone for voice tutoring."
        }
      ]
    ]
  }
}
